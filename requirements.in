# Python dependencies for the agentic content pipeline (SOURCE FILE).
#
# This is the hand-edited list. The pinned, installable lockfile is requirements.txt,
# which is regenerated weekly by the maintenance workflow
# (.github/workflows/weekly-maintenance.yml) via `pip-compile --upgrade`. Add or
# remove a package HERE, not in requirements.txt.
#
# The stack is decided per module (see CONTRIBUTING.md). To install everything from
# the lockfile:
#
#     python -m venv .venv && source .venv/bin/activate
#     pip install -r requirements.txt

# --- Ingestion scripts (Module 2): scripts/fetch_transcripts.py ---
# The web extractors (scrape_courses.py, scrape_articles.py, fetch_gdoc.py,
# fetch_semantic_scholar.py) and the YouTube channel resolver
# (fetch_youtube_channel.py) use only the standard library plus curl.
# fetch_transcripts.py (invoked by fetch_youtube_channel.py) needs this:
youtube-transcript-api>=1.0
# ingest_files.py extracts text from PDFs with pypdf; without it, PDFs fall back to
# a reference note. All its other file types use only the standard library.
pypdf>=4.0

# --- Content extraction agent (extractor_agent/) ---
# Natural-language orchestration over the extractors. Only needed for the live agent
# (`python -m extractor_agent "..."`); the deterministic scripts and `--dry-run` need
# none of these. Local-first: the default backend is a local LM Studio server, so no
# API key is required; set OPENAI_API_KEY or AZURE_OPENAI_ENDPOINT to use a cloud one.
#
# Default framework is LangChain (--framework langchain):
langchain>=1.0
langgraph
langchain-openai
# Optional alternative framework, Microsoft Agent Framework (--framework maf):
agent-framework-core
agent-framework-openai

# --- RAG index over notes and docs (rag/) ---
# Persistent vector store + local (offline) MiniLM embeddings via Chroma's default
# embedding function. No API key needed; swap the embedder in rag/store.py to use a
# hosted one.
chromadb

# --- Content writing agent (writer/) ---
# Claude for the RAG-grounded blog draft. Needs ANTHROPIC_API_KEY at run time.
anthropic

# --- Notion review output (notion_review/) ---
# Push the structured summary to Notion for human review. Needs NOTION_TOKEN.
notion-client
